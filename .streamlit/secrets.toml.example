# Copy this file to .streamlit/secrets.toml for local runs, OR paste these keys into
# the "Secrets" box of your Streamlit Community Cloud app. NEVER commit the real file.

# Reasoning model (Pydantic-AI provider:model string). Anthropic is the verified default.
LLM_MODEL = "anthropic:claude-haiku-4-5"
ANTHROPIC_API_KEY = "sk-ant-..."

# Neo4j Aura (or any publicly reachable Neo4j). Aura uses the neo4j+s:// scheme.
NEO4J_URI = "neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USERNAME = "neo4j"
NEO4J_PASSWORD = "your-aura-password"
